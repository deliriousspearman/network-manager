{
  "name": "network-diagram",
  "private": true,
  "type": "module",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm -w server run dev",
    "dev:client": "npm -w client run dev",
    "build": "npm -w server run build && npm -w client run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint 'client/src/**/*.{ts,tsx}' 'server/src/**/*.ts' 'shared/**/*.ts'",
    "lint:fix": "eslint --fix 'client/src/**/*.{ts,tsx}' 'server/src/**/*.ts' 'shared/**/*.ts'",
    "format": "prettier --write 'client/src/**/*.{ts,tsx,css}' 'server/src/**/*.ts' 'shared/**/*.ts'",
    "format:check": "prettier --check 'client/src/**/*.{ts,tsx,css}' 'server/src/**/*.ts' 'shared/**/*.ts'"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "concurrently": "^9.1.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "@vitest/coverage-v8": "^3.2.1",
    "prettier": "^3.8.1",
    "vitest": "^3.2.1"
  }
}
