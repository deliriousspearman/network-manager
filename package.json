{
  "name": "network-diagram",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm -w server run dev",
    "dev:client": "npm -w client run dev",
    "build": "npm -w server run build && npm -w client run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
