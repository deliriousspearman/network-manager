# Server
PORT=3001                      # HTTP listen port (default: 3001)
NODE_ENV=production            # Set to "production" to serve client/dist as static files

# CORS
# Comma-separated list of allowed origins. Supports wildcard subdomains (e.g. *.example.com)
# If unset, defaults to localhost:5173, localhost:8080, localhost:3001
# ALLOWED_ORIGINS=https://network.example.com,https://*.example.com

# HTTPS (optional — if both are set, server starts HTTPS instead of HTTP)
# SSL_CERT=/path/to/cert.pem
# SSL_KEY=/path/to/key.pem
# SSL_PORT=3443                # HTTPS listen port (default: 3443)

# Client (Vite dev server)
# VITE_ALLOWED_HOST=network.example.com   # Hostname to allow in Vite's dev server
